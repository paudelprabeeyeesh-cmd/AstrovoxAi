{
  "name": "astravox-ai-enterprise",
  "version": "3.0.0",
  "description": "Complete Enterprise Multi-Agent Cognitive Engine - Full Service Integration",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\" \"npm run queue:worker\" \"npm run streaming\"",
    "client": "cd frontend && live-server --port=3000 --no-browser",
    "build": "npm run build:css && npm run build:js && npm run build:3d",
    "build:css": "postcss frontend/css/**/*.css -d dist/css",
    "build:js": "webpack --mode production --config webpack.config.js",
    "build:3d": "rollup -c rollup.three.config.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "cypress run",
    "lint": "eslint backend/**/*.js frontend/js/**/*.js",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "docker:up": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build --parallel",
    "k8s:deploy": "kubectl apply -f kubernetes/",
    "k8s:rollback": "kubectl rollout undo deployment/astravox-api",
    "queue:worker": "node backend/workers/queueWorker.js",
    "queue:email": "node backend/workers/emailWorker.js",
    "cron:jobs": "node backend/cron/index.js",
    "backup:db": "node backend/scripts/backupDatabase.js",
    "migrate": "node backend/scripts/migrate.js",
    "seed": "node backend/scripts/seedDatabase.js",
    "analyze": "webpack-bundle-analyzer dist/stats.json",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop astravox-ai",
    "pm2:logs": "pm2 logs astravox-ai",
    "nginx:reload": "sudo nginx -s reload",
    "ssl:renew": "sudo certbot renew"
  },
