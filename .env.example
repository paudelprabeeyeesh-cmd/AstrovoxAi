# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend base URL. REQUIRED at build time for production deploys;
# if unset the frontend falls back to "/api" (needs a proxy to the backend).
VITE_API_URL=http://localhost:8000

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Backend CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging Configuration (see 02-Backend/app/logging_config.py)
LOG_LEVEL=INFO
LOG_FILE=logs/astravox.log

# Rate Limiting (requests per minute, per IP)
RATE_LIMIT=120/minute
